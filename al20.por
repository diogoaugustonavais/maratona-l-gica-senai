programa {
  funcao inicio() {
   inteiro ano
   escreva("Coloque um ano pava verificar se ele é/foi um ano bissexto \n")
   leia(ano)
   se (ano % 4==0) {
   escreva("Esse ano é/foi um ano de manutenção. \n")
   escreva("Esse ano é/foi bissexto.")
   }
   senao
   escreva("esse ano não é/foi um bissexto")


  }
}
