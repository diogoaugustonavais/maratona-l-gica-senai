programa {
  funcao inicio() {
    // r1= remessa 1, r2= remessa 2, rf= valor da soma das remessas
    inteiro r1, r2, rf
    escreva("Olá Almoxarifado \n")
    escreva("Qual foi a quantidade de parafusos da primeira remessa? \n")
    leia(r1)
    escreva("Agora escreva qual foi a quantidade de parafusos da segunda remessa? \n")
    leia(r2)
    rf=r1+r2
    escreva("A quantidade total de parafusos no estoque é ", rf)
  }
}
