programa {
  funcao inicio() {
    inteiro setor1,setor2
    escreva("Qual é o valor produzido pelo setor A? \n")
    leia(setor1)
    escreva("Qual é o valor produzido pelo setor B? \n")
    leia(setor2)
    se(setor1>setor2)
    escreva("O setor A produziu mais que o setor B")
    senao
    escreva("O setor B produziu mais que o setor A")
  }
}
