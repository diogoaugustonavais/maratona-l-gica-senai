programa {
  funcao inicio() {
  inteiro numero, fatorial, i
  fatorial = 1
		
		escreva("Insira um número a ser fatorado: ")
		leia(numero)
		
		
		para (i = numero; i >= 1; i--)
		{
			fatorial = fatorial * i
		}
		
		escreva("O fatorial de ", numero, " é: ", fatorial)
  
  
  
  
  
  
  
  
  
  
  
  
  }
}
