programa {
  funcao inicio() {
    real litro, distancia, litrosnecessarios
    escreva("Qual é a distancia em km que sera percorrida? \n")
    leia(distancia)
    litro=12
    litrosnecessarios=distancia/litro
    escreva("Você precisara de ", litrosnecessarios, " litros de disel para percorrer essa distancia.")

  }
}
